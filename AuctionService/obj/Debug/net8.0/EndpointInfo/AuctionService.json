{
  "openapi": "3.0.1",
  "info": {
    "title": "AuctionService",
    "version": "1.0"
  },
  "paths": {
    "/api/auctions/start": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAuctionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAuctionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartAuctionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auctions/close/{id}": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auctions/bid/{auctionId}": {
      "post": {
        "tags": [
          "Auctions"
        ],
        "parameters": [
          {
            "name": "auctionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBidDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBidDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBidDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auctions/{id}": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PlaceBidDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "format": "double"
          },
          "bidder": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": false
      },
      "StartAuctionDto": {
        "type": "object",
        "properties": {
          "vehicleId": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": false
      }
    }
  }
}